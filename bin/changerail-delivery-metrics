#!/usr/bin/env python3
"""Report ChangeRail delivery metrics from structured runtime records."""

from __future__ import annotations

import argparse
import csv
import json
import sys
from datetime import datetime
from pathlib import Path
from typing import Any

RUN_SCHEMA = "changerail.delivery-run.v1"
HISTORY_SCHEMA = "changerail.review-cycle-history.v1"
PLAN_STATUS_SCHEMA = "changerail.delivery-plan-status.v1"
SEVERITIES = ("blocker", "major", "minor")
ACCEPTANCE = ("pass", "fail", "unverifiable", "not_applicable")
UNKNOWN = "unknown"


def repo_root_from_script() -> Path:
    return Path(__file__).resolve().parents[1]


def load_json(path: Path) -> dict[str, Any] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def parse_time(value: object) -> datetime | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def seconds_between(start: object, end: object) -> str:
    started = parse_time(start)
    ended = parse_time(end)
    if not started or not ended:
        return UNKNOWN
    return str(int((ended - started).total_seconds()))


def display_number(value: object) -> str:
    if isinstance(value, bool):
        return UNKNOWN
    if isinstance(value, int):
        return str(value)
    if isinstance(value, float):
        return f"{value:g}"
    return UNKNOWN


def collect_runs(runs_dir: Path) -> list[dict[str, Any]]:
    runs: list[dict[str, Any]] = []
    for path in sorted(runs_dir.glob("*/status.json")):
        data = load_json(path)
        if data and data.get("schema") == RUN_SCHEMA:
            data["_path"] = str(path)
            runs.append(data)
    return runs


def collect_histories(reviews_dir: Path) -> dict[str, dict[str, Any]]:
    histories: dict[str, dict[str, Any]] = {}
    for path in sorted(reviews_dir.glob("*.history.json")):
        data = load_json(path)
        if not data or data.get("schema") != HISTORY_SCHEMA:
            continue
        card = data.get("card")
        if isinstance(card, dict) and isinstance(card.get("id"), str):
            data["_path"] = str(path)
            histories[card["id"]] = data
    return histories


def collect_plan_statuses(plans_dir: Path) -> list[dict[str, Any]]:
    statuses: list[dict[str, Any]] = []
    for path in sorted(plans_dir.glob("*/status.json")):
        data = load_json(path)
        if data and data.get("schema") == PLAN_STATUS_SCHEMA:
            data["_path"] = str(path)
            statuses.append(data)
    return statuses


def row_for_plan_status(status: dict[str, Any]) -> dict[str, Any]:
    plan = status.get("plan") if isinstance(status.get("plan"), dict) else {}
    summary = status.get("summary") if isinstance(status.get("summary"), dict) else {}
    cards = status.get("cards") if isinstance(status.get("cards"), list) else []
    child_run_ids = [
        card.get("run_id")
        for card in cards
        if isinstance(card, dict) and isinstance(card.get("run_id"), str)
    ]
    return {
        "queue_run_id": status.get("run_id", UNKNOWN),
        "plan_id": plan.get("id", UNKNOWN),
        "queue_result": status.get("result", UNKNOWN),
        "terminal_outcome": status.get("terminal_outcome", UNKNOWN),
        "mode": status.get("mode", UNKNOWN),
        "total_cards": display_number(summary.get("total_cards")),
        "delivered": display_number(summary.get("delivered")),
        "blocked": display_number(summary.get("blocked")),
        "no_go": display_number(summary.get("no_go")),
        "skipped": display_number(summary.get("skipped")),
        "child_run_ids": ";".join(child_run_ids) if child_run_ids else UNKNOWN,
    }


def plan_rows_and_aggregate(statuses: list[dict[str, Any]]) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    rows = [row_for_plan_status(status) for status in statuses]
    aggregate = {
        "queues": len(rows),
        "queues_delivered": sum(1 for row in rows if row["queue_result"] == "DELIVERED"),
        "queues_blocked": sum(1 for row in rows if row["queue_result"] == "BLOCKED"),
        "queues_no_go": sum(1 for row in rows if row["queue_result"] == "NO-GO"),
    }
    return rows, aggregate


def summarize_history(history: dict[str, Any] | None) -> dict[str, Any]:
    summary: dict[str, Any] = {
        "review_cycles": UNKNOWN,
        "first_review_result": UNKNOWN,
        "latest_review_result": UNKNOWN,
        "first_pass_go": UNKNOWN,
        "finding_ids": UNKNOWN,
    }
    for severity in SEVERITIES:
        summary[f"findings_{severity}"] = 0
    for verdict in ACCEPTANCE:
        summary[f"acceptance_{verdict}"] = 0
    if not history:
        for severity in SEVERITIES:
            summary[f"findings_{severity}"] = UNKNOWN
        for verdict in ACCEPTANCE:
            summary[f"acceptance_{verdict}"] = UNKNOWN
        return summary
    cycles = history.get("cycles")
    if not isinstance(cycles, list) or not cycles:
        return summary
    summary["review_cycles"] = len(cycles)
    first = cycles[0]
    latest = cycles[-1]
    summary["first_review_result"] = first.get("result", UNKNOWN)
    summary["latest_review_result"] = latest.get("result", UNKNOWN)
    summary["first_pass_go"] = "yes" if first.get("result") == "go" else "no"
    finding_ids: list[str] = []
    for cycle in cycles:
        findings = cycle.get("findings", {}) if isinstance(cycle, dict) else {}
        acceptance = cycle.get("acceptance", {}) if isinstance(cycle, dict) else {}
        details = cycle.get("finding_details", []) if isinstance(cycle, dict) else []
        if isinstance(details, list):
            for finding in details:
                if isinstance(finding, dict) and isinstance(finding.get("id"), str):
                    finding_ids.append(finding["id"])
        for severity in SEVERITIES:
            value = findings.get(severity, 0) if isinstance(findings, dict) else 0
            summary[f"findings_{severity}"] += value if isinstance(value, int) else 0
        for verdict in ACCEPTANCE:
            value = acceptance.get(verdict, 0) if isinstance(acceptance, dict) else 0
            summary[f"acceptance_{verdict}"] += value if isinstance(value, int) else 0
    summary["finding_ids"] = ";".join(finding_ids)
    return summary


def usage_value(run: dict[str, Any], key: str) -> str:
    usage = run.get("usage")
    if not isinstance(usage, dict) or not usage.get("available"):
        return UNKNOWN
    value = usage.get(key)
    if isinstance(value, int):
        return str(value)
    if key == "total_tokens":
        input_tokens = usage.get("input_tokens")
        output_tokens = usage.get("output_tokens")
        if isinstance(input_tokens, int) and isinstance(output_tokens, int):
            return str(input_tokens + output_tokens)
    return UNKNOWN


def performance(run: dict[str, Any]) -> dict[str, Any]:
    value = run.get("performance")
    return value if isinstance(value, dict) else {}


def performance_value(run: dict[str, Any], key: str) -> str:
    return display_number(performance(run).get(key))


def wall_time_value(run: dict[str, Any], timestamps: dict[str, Any]) -> str:
    value = performance_value(run, "wall_time_seconds")
    if value != UNKNOWN:
        return value
    return seconds_between(timestamps.get("started_at"), timestamps.get("ended_at"))


def slowest_commands_value(run: dict[str, Any]) -> str:
    commands = performance(run).get("slowest_commands")
    if not isinstance(commands, list) or not commands:
        return UNKNOWN
    parts: list[str] = []
    for command in commands:
        if not isinstance(command, dict):
            continue
        text = command.get("command")
        duration = display_number(command.get("duration_seconds"))
        if isinstance(text, str) and text and duration != UNKNOWN:
            parts.append(f"{text}:{duration}s")
    return ";".join(parts) if parts else UNKNOWN


def review_performance(run: dict[str, Any]) -> dict[str, Any]:
    review = performance(run).get("review")
    return review if isinstance(review, dict) else {}


def review_timeline_value(history: dict[str, Any] | None, run: dict[str, Any]) -> str:
    cycles = history.get("cycles") if isinstance(history, dict) else None
    if not isinstance(cycles, list) or not cycles:
        cycles = review_performance(run).get("cycles")
    if not isinstance(cycles, list) or not cycles:
        return UNKNOWN
    parts: list[str] = []
    for cycle in cycles:
        if not isinstance(cycle, dict):
            continue
        review_cycle = cycle.get("review_cycle")
        result = cycle.get("result", UNKNOWN)
        reviewed_at = cycle.get("reviewed_at")
        if isinstance(review_cycle, int) and isinstance(result, str) and isinstance(reviewed_at, str):
            parts.append(f"{review_cycle}:{result}@{reviewed_at}")
    return ";".join(parts) if parts else UNKNOWN


def review_performance_value(run: dict[str, Any], key: str) -> str:
    return display_number(review_performance(run).get(key))


def row_for_run(run: dict[str, Any], history: dict[str, Any] | None) -> dict[str, Any]:
    card = run.get("card") if isinstance(run.get("card"), dict) else {}
    timestamps = run.get("timestamps") if isinstance(run.get("timestamps"), dict) else {}
    row = {
        "run_id": run.get("run_id", UNKNOWN),
        "card_id": card.get("id", UNKNOWN),
        "result": run.get("result", UNKNOWN),
        "wall_time_seconds": wall_time_value(run, timestamps),
        "input_tokens": usage_value(run, "input_tokens"),
        "cached_input_tokens": usage_value(run, "cached_input_tokens"),
        "uncached_input_tokens": usage_value(run, "uncached_input_tokens"),
        "output_tokens": usage_value(run, "output_tokens"),
        "reasoning_tokens": usage_value(run, "reasoning_tokens"),
        "total_tokens": usage_value(run, "total_tokens"),
        "agent_message_count": performance_value(run, "agent_message_count"),
        "command_execution_count": performance_value(run, "command_execution_count"),
        "file_change_count": performance_value(run, "file_change_count"),
        "slowest_commands": slowest_commands_value(run),
        "review_timeline": review_timeline_value(history, run),
        "first_review_latency_seconds": review_performance_value(run, "first_review_latency_seconds"),
        "time_to_final_go_seconds": review_performance_value(run, "time_to_final_go_seconds"),
    }
    row.update(summarize_history(history))
    if row["review_cycles"] == UNKNOWN:
        review_cycle_count = review_performance(run).get("cycle_count")
        if isinstance(review_cycle_count, int):
            row["review_cycles"] = str(review_cycle_count)
    return row


def rows_and_aggregate(runs: list[dict[str, Any]], histories: dict[str, dict[str, Any]]) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    rows = []
    for run in runs:
        card = run.get("card") if isinstance(run.get("card"), dict) else {}
        card_id = card.get("id") if isinstance(card.get("id"), str) else ""
        rows.append(row_for_run(run, histories.get(card_id)))
    aggregate: dict[str, Any] = {
        "runs": len(rows),
        "delivered": sum(1 for row in rows if row["result"] == "DELIVERED"),
        "blocked": sum(1 for row in rows if row["result"] == "BLOCKED"),
        "no_go": sum(1 for row in rows if row["result"] == "NO-GO"),
    }
    known_first = [row for row in rows if row["first_pass_go"] != UNKNOWN]
    if known_first:
        passed = sum(1 for row in known_first if row["first_pass_go"] == "yes")
        aggregate["first_pass_go_rate"] = f"{passed}/{len(known_first)}"
    else:
        aggregate["first_pass_go_rate"] = UNKNOWN
    for severity in SEVERITIES:
        values = [row[f"findings_{severity}"] for row in rows if row[f"findings_{severity}"] != UNKNOWN]
        aggregate[f"findings_{severity}"] = sum(int(value) for value in values) if values else UNKNOWN
    return rows, aggregate


def print_text(rows: list[dict[str, Any]], aggregate: dict[str, Any], queue_rows: list[dict[str, Any]], queue_aggregate: dict[str, Any]) -> None:
    print("per-run:")
    for row in rows:
        print(
            f"- {row['run_id']} card={row['card_id']} result={row['result']} "
            f"first_review={row['first_review_result']} latest_review={row['latest_review_result']} "
            f"review_cycles={row['review_cycles']} wall_time_seconds={row['wall_time_seconds']} "
            f"input_tokens={row['input_tokens']} cached_input_tokens={row['cached_input_tokens']} "
            f"uncached_input_tokens={row['uncached_input_tokens']} output_tokens={row['output_tokens']} "
            f"reasoning_tokens={row['reasoning_tokens']} total_tokens={row['total_tokens']} "
            f"agent_message_count={row['agent_message_count']} command_execution_count={row['command_execution_count']} "
            f"file_change_count={row['file_change_count']} slowest_commands={row['slowest_commands']} "
            f"review_timeline={row['review_timeline']} "
            f"first_review_latency_seconds={row['first_review_latency_seconds']} "
            f"time_to_final_go_seconds={row['time_to_final_go_seconds']} "
            f"finding_ids={row['finding_ids']}"
        )
    print("aggregate:")
    for key in sorted(aggregate):
        print(f"- {key}: {aggregate[key]}")
    print("queues:")
    for row in queue_rows:
        print(
            f"- {row['queue_run_id']} plan={row['plan_id']} result={row['queue_result']} "
            f"terminal_outcome={row['terminal_outcome']} mode={row['mode']} "
            f"total_cards={row['total_cards']} delivered={row['delivered']} "
            f"blocked={row['blocked']} no_go={row['no_go']} skipped={row['skipped']} "
            f"child_run_ids={row['child_run_ids']}"
        )
    print("queue_aggregate:")
    for key in sorted(queue_aggregate):
        print(f"- {key}: {queue_aggregate[key]}")


def print_csv(rows: list[dict[str, Any]]) -> None:
    fields = [
        "run_id",
        "card_id",
        "result",
        "wall_time_seconds",
        "input_tokens",
        "cached_input_tokens",
        "uncached_input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "total_tokens",
        "agent_message_count",
        "command_execution_count",
        "file_change_count",
        "slowest_commands",
        "review_cycles",
        "review_timeline",
        "first_review_latency_seconds",
        "time_to_final_go_seconds",
        "first_review_result",
        "latest_review_result",
        "first_pass_go",
        "findings_blocker",
        "findings_major",
        "findings_minor",
        "finding_ids",
        "acceptance_pass",
        "acceptance_fail",
        "acceptance_unverifiable",
        "acceptance_not_applicable",
    ]
    writer = csv.DictWriter(sys.stdout, fieldnames=fields, extrasaction="ignore")
    writer.writeheader()
    for row in rows:
        writer.writerow(row)


def parse_args(argv: list[str]) -> argparse.Namespace:
    root = repo_root_from_script()
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--runs-dir", type=Path, default=root / ".runtime" / "changerail" / "delivery-runs")
    parser.add_argument("--reviews-dir", type=Path, default=root / ".runtime" / "changerail" / "reviews")
    parser.add_argument("--plans-dir", type=Path, default=root / ".runtime" / "changerail" / "delivery-plans")
    parser.add_argument("--csv", action="store_true", help="emit per-run CSV")
    parser.add_argument("--json", action="store_true", help="emit rows and aggregate as JSON")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    rows, aggregate = rows_and_aggregate(collect_runs(args.runs_dir), collect_histories(args.reviews_dir))
    queue_rows, queue_aggregate = plan_rows_and_aggregate(collect_plan_statuses(args.plans_dir))
    if args.csv:
        print_csv(rows)
    elif args.json:
        print(
            json.dumps(
                {"rows": rows, "aggregate": aggregate, "queues": queue_rows, "queue_aggregate": queue_aggregate},
                ensure_ascii=False,
                indent=2,
                sort_keys=True,
            )
        )
    else:
        print_text(rows, aggregate, queue_rows, queue_aggregate)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
