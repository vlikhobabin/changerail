#!/usr/bin/env python3
"""Run one ChangeRail delivery card non-interactively and write structured runtime status."""

from __future__ import annotations

import argparse
import json
import os
import secrets
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import asdict, dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

SCHEMA = "changerail.delivery-run.v1"
AUTH_ENV_VARS = ("CODEX_AUTH_TOKEN", "OPENAI_API_KEY")
AUTH_MARKER_FILES = ("auth.json", "auth.toml")
TERMINAL_OUTCOMES = ("NO-GO", "BLOCKED", "DELIVERED")
TERMINAL_FIELD_KEYS = {"terminal_outcome", "terminal-outcome", "outcome", "result"}
BOARD_COLUMNS = ("1.backlog", "2.todo", "3.inprogress", "4.done", "5.canceled")
MAX_TIMELINE_EVENTS = 100
MAX_COMMANDS = 50
MAX_SLOW_COMMANDS = 5


@dataclass
class Check:
    name: str
    status: str
    message: str


def repo_root_from_script() -> Path:
    return Path(__file__).resolve().parents[1]


def invocation_workspace() -> Path:
    cwd = Path.cwd()
    result = subprocess.run(
        ["git", "-C", str(cwd), "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode == 0 and result.stdout.strip():
        return Path(result.stdout.strip()).resolve(strict=False)
    return cwd.resolve(strict=False)


def resolve_path(path: Path, base: Path | None = None) -> Path:
    path = path.expanduser()
    if path.is_absolute():
        return path.resolve(strict=False)
    anchor = base or Path.cwd()
    return (anchor / path).resolve(strict=False)


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def utc_run_id() -> str:
    return f"{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}-{secrets.token_hex(4)}"


def atomic_write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=path.parent, delete=False) as handle:
        tmp_path = Path(handle.name)
        json.dump(data, handle, ensure_ascii=False, indent=2, sort_keys=True)
        handle.write("\n")
    os.replace(tmp_path, path)


def parse_utc(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def elapsed_seconds(start: datetime | None, end: datetime | None) -> float | None:
    if start is None or end is None:
        return None
    seconds = (end - start).total_seconds()
    if seconds < 0:
        return None
    return round(seconds, 3)


def git_head(root: Path) -> str | None:
    result = subprocess.run(
        ["git", "-C", str(root), "rev-parse", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def effective_codex_home(args: argparse.Namespace) -> Path:
    root = args.workspace.resolve(strict=False)
    configured = os.environ.get("CODEX_HOME")
    if configured:
        path = Path(configured).expanduser()
        return path if path.is_absolute() else root / path
    return root / ".codex"


def child_environment(args: argparse.Namespace) -> dict[str, str]:
    root = args.workspace.resolve(strict=False)
    env = os.environ.copy()
    env["CODEX_WORKDIR"] = str(root)
    env["CODEX_HOME"] = str(effective_codex_home(args))
    return env


def stale_symlinks(root: Path) -> list[str]:
    if not root.exists():
        return []
    stale: list[str] = []
    for path in root.rglob("*"):
        try:
            if path.is_symlink() and not path.exists():
                stale.append(str(path.relative_to(root)))
        except OSError:
            stale.append(str(path))
    return sorted(stale)


def auth_state(codex_home: Path, env: dict[str, str]) -> Check:
    if any(env.get(name) for name in AUTH_ENV_VARS):
        return Check("CODEX auth", "pass", "auth environment variable is set")
    for name in AUTH_MARKER_FILES:
        if (codex_home / name).is_file():
            return Check("CODEX auth", "pass", f"{codex_home / name}")
    return Check("CODEX auth", "fail", "no auth marker or supported auth environment variable found")


def sanitized_endpoint(url: str) -> str:
    parts = urllib.parse.urlsplit(url)
    scheme = parts.scheme or "unknown"
    host = parts.hostname or "unknown-host"
    port = f":{parts.port}" if parts.port is not None else ""
    return f"{scheme}://{host}{port}"


def record_commit(record: dict[str, Any], root: Path) -> None:
    head = git_head(root)
    if head:
        record.setdefault("workspace", {})["head_commit"] = head
        record["commit"] = head


def card_id(card: str) -> str:
    return Path(card).name.removesuffix(".md")


def repository_relative(path: Path, root: Path) -> str:
    try:
        return path.relative_to(root).as_posix()
    except ValueError:
        return path.as_posix()


def current_card_locations(root: Path, card: str) -> list[str]:
    filename = Path(card).name
    seen: set[str] = set()
    locations: list[str] = []
    direct = root / card
    if direct.exists():
        relative = repository_relative(direct, root)
        seen.add(relative)
        locations.append(relative)
    for column in BOARD_COLUMNS:
        candidate = root / "openspec" / "board" / column / filename
        if not candidate.exists():
            continue
        relative = repository_relative(candidate, root)
        if relative not in seen:
            seen.add(relative)
            locations.append(relative)
    return sorted(locations)


def card_is_published(root: Path, card: str) -> bool:
    locations = current_card_locations(root, card)
    return bool(locations) and all(path.startswith("openspec/board/4.done/") for path in locations)


def changed_path_count(root: Path) -> int | None:
    result = subprocess.run(
        ["git", "-C", str(root), "status", "--porcelain"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    return sum(1 for line in result.stdout.splitlines() if line.strip())


def review_history_path(root: Path, card: str) -> Path:
    return root / ".runtime" / "changerail" / "reviews" / f"{card_id(card)}.history.json"


def delivery_manifest_path(root: Path, card: str) -> Path:
    return root / ".runtime" / "changerail" / "delivery-manifests" / f"{card_id(card)}.json"


def load_json_object(path: Path) -> dict[str, Any] | None:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return payload if isinstance(payload, dict) else None


def review_timing(root: Path, card: str, started_at: str) -> dict[str, Any] | None:
    history = load_json_object(review_history_path(root, card))
    cycles = history.get("cycles") if history else None
    if not isinstance(cycles, list):
        return None
    started = parse_utc(started_at)
    entries: list[dict[str, Any]] = []
    previous_reviewed: datetime | None = None
    final_go: datetime | None = None
    first_reviewed: datetime | None = None
    for cycle in cycles:
        if not isinstance(cycle, dict):
            continue
        review_cycle = cycle.get("review_cycle")
        if not isinstance(review_cycle, int):
            continue
        entry: dict[str, Any] = {"review_cycle": review_cycle}
        result = cycle.get("result")
        if result in {"go", "no-go"}:
            entry["result"] = result
        reviewed_at_raw = cycle.get("reviewed_at")
        reviewed_at = parse_utc(reviewed_at_raw if isinstance(reviewed_at_raw, str) else None)
        if isinstance(reviewed_at_raw, str):
            entry["reviewed_at"] = reviewed_at_raw
        if reviewed_at is not None:
            if first_reviewed is None:
                first_reviewed = reviewed_at
            latency = elapsed_seconds(started, reviewed_at)
            if latency is not None:
                entry["latency_seconds"] = latency
            since_previous = elapsed_seconds(previous_reviewed, reviewed_at)
            if since_previous is not None:
                entry["since_previous_seconds"] = since_previous
            previous_reviewed = reviewed_at
            if result == "go":
                final_go = reviewed_at
        entries.append(entry)
    if not entries:
        return None
    summary: dict[str, Any] = {
        "cycle_count": len(entries),
        "cycles": entries,
    }
    first_latency = elapsed_seconds(started, first_reviewed)
    if first_latency is not None:
        summary["first_review_latency_seconds"] = first_latency
    final_latency = elapsed_seconds(started, final_go)
    if final_latency is not None:
        summary["time_to_final_go_seconds"] = final_latency
    return summary


def publish_timing(root: Path, card: str, started_at: str) -> dict[str, Any] | None:
    manifest = load_json_object(delivery_manifest_path(root, card))
    publish = manifest.get("publish") if manifest else None
    if not isinstance(publish, dict):
        return None
    pushed_at_raw = publish.get("pushed_at")
    if not isinstance(pushed_at_raw, str):
        return None
    started = parse_utc(started_at)
    pushed_at = parse_utc(pushed_at_raw)
    summary: dict[str, Any] = {"pushed_at": pushed_at_raw}
    latency = elapsed_seconds(started, pushed_at)
    if latency is not None:
        summary["latency_seconds"] = latency
    return summary


class PerformanceCollector:
    def __init__(self) -> None:
        self.started_monotonic = time.monotonic()
        self.event_counts: dict[str, int] = {}
        self.agent_message_count = 0
        self.command_starts: dict[str, dict[str, Any]] = {}
        self.commands: list[dict[str, Any]] = []
        self.timeline: list[dict[str, Any]] = []

    def observe_line(self, line: str) -> None:
        observed_at = utc_now()
        observed_monotonic = time.monotonic()
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            return
        if not isinstance(event, dict):
            return
        event_type = self.event_type(event)
        self.event_counts[event_type] = self.event_counts.get(event_type, 0) + 1
        item = event.get("item") if isinstance(event.get("item"), dict) else {}
        item_type = item.get("type")
        if item_type == "agent_message" or event_type in {"assistant-message", "agent_message"}:
            self.agent_message_count += 1
        timeline_entry: dict[str, Any] = {
            "observed_at": observed_at,
            "event_type": event_type,
        }
        event_id = event.get("id")
        if isinstance(event_id, str) and event_id:
            timeline_entry["event_id"] = event_id
        item_id = item.get("id")
        if isinstance(item_id, str) and item_id:
            timeline_entry["item_id"] = item_id
        outcome = event_terminal_outcome(event)
        if outcome:
            timeline_entry["terminal_outcome"] = outcome
        if item_type == "command_execution":
            self.observe_command(item, event_type, observed_at, observed_monotonic, timeline_entry)
        self.append_timeline(timeline_entry)

    def event_type(self, event: dict[str, Any]) -> str:
        for key in ("type", "event", "name"):
            value = event.get(key)
            if isinstance(value, str) and value:
                return value
        return "unknown"

    def observe_command(
        self,
        item: dict[str, Any],
        event_type: str,
        observed_at: str,
        observed_monotonic: float,
        timeline_entry: dict[str, Any],
    ) -> None:
        command_id = item.get("id")
        if not isinstance(command_id, str) or not command_id:
            command_id = f"command-{len(self.command_starts) + len(self.commands) + 1}"
        command = item.get("command")
        timeline_entry["command_id"] = command_id
        if isinstance(command, str) and command:
            timeline_entry["command"] = command
        status = item.get("status")
        if event_type.endswith(".started") or status == "in_progress":
            self.command_starts[command_id] = {
                "command_id": command_id,
                "command": command if isinstance(command, str) else None,
                "started_at": observed_at,
                "started_monotonic": observed_monotonic,
            }
            return
        if event_type.endswith(".completed") or status == "completed":
            start = self.command_starts.pop(command_id, {})
            summary: dict[str, Any] = {"command_id": command_id}
            command_value = command if isinstance(command, str) else start.get("command")
            if isinstance(command_value, str) and command_value:
                summary["command"] = command_value
            started_at = start.get("started_at")
            if isinstance(started_at, str):
                summary["started_at"] = started_at
            summary["ended_at"] = observed_at
            started_monotonic = start.get("started_monotonic")
            if isinstance(started_monotonic, (int, float)):
                duration = round(max(0.0, observed_monotonic - float(started_monotonic)), 6)
                summary["duration_seconds"] = duration
                timeline_entry["duration_seconds"] = duration
            exit_code = item.get("exit_code")
            if isinstance(exit_code, int):
                summary["exit_code"] = exit_code
            self.commands.append(summary)

    def append_timeline(self, entry: dict[str, Any]) -> None:
        if len(self.timeline) >= MAX_TIMELINE_EVENTS:
            self.timeline.pop(0)
        self.timeline.append(entry)

    def record_terminal(self, outcome: str) -> None:
        self.append_timeline(
            {
                "observed_at": utc_now(),
                "event_type": "terminal_outcome",
                "terminal_outcome": outcome,
            }
        )

    def summary(self, root: Path, card: str, started_at: str) -> dict[str, Any]:
        data: dict[str, Any] = {
            "wall_time_seconds": round(max(0.0, time.monotonic() - self.started_monotonic), 3),
        }
        if self.event_counts:
            data["event_counts"] = dict(sorted(self.event_counts.items()))
        data["agent_message_count"] = self.agent_message_count
        data["command_execution_count"] = len(self.commands)
        changed = changed_path_count(root)
        if changed is not None:
            data["file_change_count"] = changed
        if self.commands:
            commands = self.commands[-MAX_COMMANDS:]
            data["commands"] = commands
            data["slowest_commands"] = sorted(
                commands,
                key=lambda command: command.get("duration_seconds", -1),
                reverse=True,
            )[:MAX_SLOW_COMMANDS]
        if self.timeline:
            data["timeline"] = self.timeline
        review = review_timing(root, card, started_at)
        if review:
            data["review"] = review
        publish = publish_timing(root, card, started_at)
        if publish:
            data["publish"] = publish
        return data


def base_record(args: argparse.Namespace, phase: str, result: str) -> dict[str, Any]:
    root = args.workspace.resolve(strict=False)
    record: dict[str, Any] = {
        "schema": SCHEMA,
        "run_id": args.run_id,
        "updated_at": utc_now(),
        "workspace": {
            "root": str(root),
            "repository": root.name,
        },
        "card": {
            "id": card_id(args.card),
            "path": args.card,
        },
        "phase": phase,
        "result": result,
        "timestamps": {
            "started_at": args.started_at,
        },
        "command": {
            "argv": [],
            "launcher": str(args.launcher),
            "stdin": "closed",
            "json": True,
        },
        "usage": {
            "available": False,
            "reason": "usage not observed",
        },
    }
    record_commit(record, root)
    if args.model:
        record["command"]["model"] = args.model
    if args.reasoning_effort:
        record["command"]["reasoning_effort"] = args.reasoning_effort
    return record


def status_path(args: argparse.Namespace) -> Path:
    return args.runtime_root / args.run_id / "status.json"


def log_paths(args: argparse.Namespace) -> tuple[Path, Path]:
    run_dir = args.runtime_root / args.run_id
    return run_dir / "stdout.jsonl", run_dir / "stderr.log"


def check_preflight(args: argparse.Namespace) -> list[Check]:
    root = args.workspace.resolve(strict=False)
    launcher = args.launcher
    env = child_environment(args)
    codex_home = effective_codex_home(args)
    config = codex_home / "config.toml"
    stale = stale_symlinks(codex_home)
    checks = [
        Check("workspace", "pass" if root.is_dir() else "fail", str(root)),
        Check("CODEX_WORKDIR", "pass", env["CODEX_WORKDIR"]),
        Check("launcher exists", "pass" if launcher.is_file() else "fail", str(launcher)),
        Check("launcher executable", "pass" if os.access(launcher, os.X_OK) else "fail", str(launcher)),
        Check("CODEX_HOME", "pass" if codex_home.exists() else "fail", str(codex_home)),
        Check("CODEX config", "pass" if config.is_file() else "skip", str(config)),
        auth_state(codex_home, env),
        Check(
            "CODEX_HOME symlinks",
            "pass" if not stale else "fail",
            "no stale symlinks" if not stale else ", ".join(stale[:10]),
        ),
        Check("codex binary", "pass" if shutil.which("codex") else "fail", shutil.which("codex") or "not found"),
    ]
    if args.connectivity_url:
        try:
            with urllib.request.urlopen(args.connectivity_url, timeout=args.connectivity_timeout) as response:
                checks.append(Check("connectivity", "pass", f"{sanitized_endpoint(args.connectivity_url)} status={response.status}"))
        except (OSError, urllib.error.URLError) as exc:
            checks.append(Check("connectivity", "fail", f"{sanitized_endpoint(args.connectivity_url)} error={exc.__class__.__name__}"))
    else:
        checks.append(Check("connectivity", "skip", "no connectivity URL provided"))
    return checks


def build_command(args: argparse.Namespace) -> list[str]:
    prompt = "$changerail-deliver " + args.card
    for value in args.deliver_arg:
        prompt += " " + value
    command = [str(args.launcher), "exec", "--json"]
    if args.model:
        command.extend(["-m", args.model])
    if args.reasoning_effort:
        command.extend(["-c", f'model_reasoning_effort="{args.reasoning_effort}"'])
    command.append(prompt)
    return command


def parse_usage(stdout_path: Path) -> dict[str, Any]:
    usage: dict[str, Any] = {
        "available": False,
        "reason": "usage not observed",
    }
    try:
        lines = stdout_path.read_text(encoding="utf-8").splitlines()
    except OSError:
        return usage
    for line in lines:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        candidate = event.get("usage") if isinstance(event, dict) else None
        if not isinstance(candidate, dict):
            candidate = event.get("token_usage") if isinstance(event, dict) else None
        if not isinstance(candidate, dict):
            continue
        parsed = {"available": True}
        for source, target in (
            ("input_tokens", "input_tokens"),
            ("prompt_tokens", "input_tokens"),
            ("output_tokens", "output_tokens"),
            ("completion_tokens", "output_tokens"),
            ("cached_input_tokens", "cached_input_tokens"),
            ("input_cached_tokens", "cached_input_tokens"),
            ("uncached_input_tokens", "uncached_input_tokens"),
            ("reasoning_tokens", "reasoning_tokens"),
            ("total_tokens", "total_tokens"),
        ):
            value = candidate.get(source)
            if isinstance(value, int) and value >= 0:
                parsed[target] = value
        for source, target in (
            ("prompt_tokens_details", "cached_input_tokens"),
            ("input_tokens_details", "cached_input_tokens"),
        ):
            details = candidate.get(source)
            if isinstance(details, dict):
                value = details.get("cached_tokens")
                if isinstance(value, int) and value >= 0:
                    parsed[target] = value
        for source in ("completion_tokens_details", "output_tokens_details"):
            details = candidate.get(source)
            if isinstance(details, dict):
                value = details.get("reasoning_tokens")
                if isinstance(value, int) and value >= 0:
                    parsed["reasoning_tokens"] = value
        return parsed
    return usage


def normalize_terminal_value(value: str) -> str | None:
    normalized = value.strip().lower().replace("_", "-").replace(" ", "-")
    if not normalized:
        return None
    if normalized in {"delivered", "delivery/delivered"}:
        return "DELIVERED"
    if normalized in {"no-go", "nogo"} or normalized.endswith("/no-go"):
        return "NO-GO"
    if "awaiting-review" in normalized or normalized in {"awaiting-external-review", "awaiting-review"}:
        return "BLOCKED"
    if normalized in {"blocked", "delivery/blocked"}:
        return "BLOCKED"
    return None


def event_terminal_outcome(event: Any) -> str | None:
    if not isinstance(event, dict):
        return None
    for key in ("type", "event", "name"):
        value = event.get(key)
        if isinstance(value, str):
            outcome = normalize_terminal_value(value)
            if outcome:
                return outcome
    for key in TERMINAL_FIELD_KEYS:
        value = event.get(key)
        if isinstance(value, str):
            outcome = normalize_terminal_value(value)
            if outcome:
                return outcome
    return None


def stdout_terminal_outcome(stdout_path: Path) -> str | None:
    try:
        text = stdout_path.read_text(encoding="utf-8")
    except OSError:
        return None
    outcome: str | None = None
    for line in text.splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        candidate = event_terminal_outcome(event)
        if candidate:
            outcome = candidate
    return outcome


def review_verdict_path(root: Path, card: str) -> Path:
    return root / ".runtime" / "changerail" / "reviews" / f"{card_id(card)}.json"


def review_verdict_fallback_outcome(args: argparse.Namespace) -> str | None:
    root = args.workspace.resolve(strict=False)
    verdict = review_verdict_path(root, args.card)
    if not verdict.is_file() or card_is_published(root, args.card):
        return None

    helper = repo_root_from_script() / "scripts" / "changerail_review_verdict.py"
    if not helper.is_file():
        return "BLOCKED"
    result = subprocess.run(
        [
            sys.executable,
            str(helper),
            "validate",
            str(verdict),
            "--check-fresh",
            "--workspace",
            str(root),
            "--json",
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return "BLOCKED"
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return "BLOCKED"
    if payload.get("result") == "no-go":
        return "NO-GO"
    if payload.get("result") == "go":
        return "BLOCKED"
    return None


def command_preflight(args: argparse.Namespace) -> int:
    args.started_at = utc_now()
    checks = check_preflight(args)
    record = base_record(args, "preflight", "DELIVERED" if all(c.status != "fail" for c in checks) else "BLOCKED")
    record["preflight"] = {"checks": [asdict(check) for check in checks]}
    record["timestamps"]["ended_at"] = utc_now()
    record_commit(record, args.workspace.resolve(strict=False))
    if args.write_status:
        atomic_write_json(status_path(args), record)
    print(json.dumps(record, ensure_ascii=False, indent=2, sort_keys=True) if args.json else record["result"])
    return 0 if record["result"] == "DELIVERED" else 1


def command_run(args: argparse.Namespace) -> int:
    args.started_at = utc_now()
    root = args.workspace.resolve(strict=False)
    args.runtime_root.mkdir(parents=True, exist_ok=True)
    checks = check_preflight(args)
    stdout_path, stderr_path = log_paths(args)
    command = build_command(args)
    record = base_record(args, "delivery", "RUNNING")
    record["command"]["argv"] = command
    record["preflight"] = {"checks": [asdict(check) for check in checks]}
    record["logs"] = {"stdout": str(stdout_path), "stderr": str(stderr_path)}
    if any(check.status == "fail" for check in checks):
        record["phase"] = "terminal"
        record["result"] = "BLOCKED"
        record["terminal_outcome"] = "BLOCKED"
        record["timestamps"]["ended_at"] = utc_now()
        atomic_write_json(status_path(args), record)
        print("terminal_outcome: BLOCKED")
        print(f"status: {status_path(args)}")
        return 1
    atomic_write_json(status_path(args), record)
    stdout_path.parent.mkdir(parents=True, exist_ok=True)
    performance = PerformanceCollector()
    with stdout_path.open("w", encoding="utf-8") as stdout, stderr_path.open("w", encoding="utf-8") as stderr:
        process = subprocess.Popen(
            command,
            cwd=root,
            env=child_environment(args),
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=stderr,
            text=True,
            bufsize=1,
        )
        record["process"] = {"pid": process.pid}
        atomic_write_json(status_path(args), record)
        if process.stdout is not None:
            for line in process.stdout:
                stdout.write(line)
                stdout.flush()
                performance.observe_line(line)
        exit_code = process.wait()
    structured_outcome = stdout_terminal_outcome(stdout_path)
    fallback_outcome = review_verdict_fallback_outcome(args) if structured_outcome is None else None
    outcome = structured_outcome or fallback_outcome or ("DELIVERED" if exit_code == 0 else "BLOCKED")
    if exit_code != 0 and outcome == "DELIVERED":
        outcome = "BLOCKED"
    record["phase"] = "terminal"
    record["result"] = outcome
    record["terminal_outcome"] = outcome
    record.setdefault("process", {})["exit_code"] = exit_code
    record["usage"] = parse_usage(stdout_path)
    performance.record_terminal(outcome)
    record["performance"] = performance.summary(root, args.card, args.started_at)
    record["timestamps"]["ended_at"] = utc_now()
    record["updated_at"] = utc_now()
    record_commit(record, root)
    atomic_write_json(status_path(args), record)
    print(f"terminal_outcome: {outcome}")
    print(f"status: {status_path(args)}")
    return 0 if outcome == "DELIVERED" else 1


def add_common(parser: argparse.ArgumentParser) -> None:
    root = repo_root_from_script()
    parser.add_argument("card", help="single repository-relative board card path")
    parser.add_argument("--workspace", type=Path)
    parser.add_argument("--runtime-root", type=Path)
    parser.add_argument("--run-id", default=utc_run_id())
    parser.add_argument("--launcher", type=Path, default=root / "bin" / "codex")
    parser.add_argument("--connectivity-url")
    parser.add_argument("--connectivity-timeout", type=float, default=5.0)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    run = subparsers.add_parser("run", help="run non-interactive ChangeRail delivery")
    add_common(run)
    run.add_argument("--model")
    run.add_argument("--reasoning-effort")
    run.add_argument(
        "--deliver-arg",
        action="append",
        default=[],
        help="extra argument appended to the $changerail-deliver prompt, repeatable",
    )
    run.set_defaults(func=command_run)

    preflight = subparsers.add_parser("preflight", help="run preflight checks only")
    add_common(preflight)
    preflight.add_argument("--json", action="store_true")
    preflight.add_argument("--write-status", action="store_true")
    preflight.set_defaults(func=command_preflight, model=None, reasoning_effort=None, deliver_arg=[])
    args = parser.parse_args(argv)
    args.workspace = resolve_path(args.workspace) if args.workspace else invocation_workspace()
    if args.runtime_root:
        args.runtime_root = resolve_path(args.runtime_root, args.workspace)
    else:
        args.runtime_root = args.workspace / ".runtime" / "changerail" / "delivery-runs"
    args.launcher = resolve_path(args.launcher)
    return args


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
