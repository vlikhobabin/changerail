#!/usr/bin/env python3
"""Launch the OPSX review verdict helper from a repo or symlinked wrapper."""

from __future__ import annotations

import json
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
SCRIPT = ROOT / "scripts" / "opsx_review_verdict.py"


def missing_helper() -> int:
    payload = {
        "ok": False,
        "diagnostic": {
            "kind": "opsx_review_verdict",
            "code": "helper_missing",
            "message": "OPSX review verdict helper could not be found from the wrapper.",
            "expected_path": str(SCRIPT),
        },
    }
    print(json.dumps(payload, ensure_ascii=False), file=sys.stderr)
    return 2


def main() -> int:
    if not SCRIPT.is_file():
        return missing_helper()
    sys.path.insert(0, str(ROOT / "scripts"))
    from opsx_review_verdict import main as verdict_main

    return verdict_main()


if __name__ == "__main__":
    raise SystemExit(main())
