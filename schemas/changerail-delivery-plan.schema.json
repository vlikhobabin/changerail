{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changerail.local/schemas/changerail-delivery-plan.schema.json",
  "title": "ChangeRail delivery plan",
  "type": "object",
  "required": ["schema", "id", "workspaces", "cards"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "changerail.delivery-plan.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": {
      "type": "string"
    },
    "max_parallel": {
      "type": "integer",
      "minimum": 1
    },
    "per_workspace_parallelism": {
      "const": 1
    },
    "push_mode": {
      "enum": ["push", "no-push"]
    },
    "workspaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workspace"
      }
    },
    "waves": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wave"
      }
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/card"
      }
    }
  },
  "$defs": {
    "alias": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\.\\.)(?!.*://)(?!.*@)(?!.*\\$\\{).+$"
    },
    "workspace": {
      "type": "object",
      "required": ["alias", "path"],
      "additionalProperties": false,
      "properties": {
        "alias": {
          "$ref": "#/$defs/alias"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "wave": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "card": {
      "type": "object",
      "required": ["id", "workspace", "card"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "workspace": {
          "$ref": "#/$defs/alias"
        },
        "card": {
          "$ref": "#/$defs/relativePath"
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "recovery_for": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "wave": {
          "type": "integer",
          "minimum": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_effort": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
