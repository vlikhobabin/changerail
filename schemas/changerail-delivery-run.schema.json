{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://changerail.local/schemas/changerail-delivery-run.schema.json",
  "title": "ChangeRail delivery run",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "updated_at",
    "workspace",
    "card",
    "phase",
    "result",
    "timestamps",
    "command",
    "usage"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "changerail.delivery-run.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace": {
      "type": "object",
      "required": ["root"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "head_commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "card": {
      "type": "object",
      "required": ["id", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase": {
      "enum": ["preflight", "delivery", "terminal"]
    },
    "result": {
      "enum": ["RUNNING", "DELIVERED", "NO-GO", "BLOCKED"]
    },
    "timestamps": {
      "type": "object",
      "required": ["started_at"],
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["argv", "launcher", "stdin", "json"],
      "additionalProperties": false,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "launcher": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_effort": {
          "type": "string",
          "minLength": 1
        },
        "stdin": {
          "const": "closed"
        },
        "json": {
          "type": "boolean"
        }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "exit_code": {
          "type": "integer"
        }
      }
    },
    "terminal_outcome": {
      "enum": ["DELIVERED", "NO-GO", "BLOCKED"]
    },
    "terminal_reason": {
      "$ref": "#/$defs/terminalReason"
    },
    "commit": {
      "type": "string",
      "minLength": 1
    },
    "preflight": {
      "type": "object",
      "required": ["checks"],
      "additionalProperties": false,
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdout": {
          "type": "string",
          "minLength": 1
        },
        "stderr": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "usage": {
      "type": "object",
      "required": ["available"],
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cached_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "uncached_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoning_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wall_time_seconds": {
          "type": "number",
          "minimum": 0
        },
        "event_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "agent_message_count": {
          "type": "integer",
          "minimum": 0
        },
        "command_execution_count": {
          "type": "integer",
          "minimum": 0
        },
        "file_change_count": {
          "type": "integer",
          "minimum": 0
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandTiming"
          }
        },
        "slowest_commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandTiming"
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timelineEvent"
          }
        },
        "review": {
          "$ref": "#/$defs/reviewTiming"
        },
        "publish": {
          "$ref": "#/$defs/publishTiming"
        }
      }
    }
  },
  "$defs": {
    "commandTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "exit_code": {
          "type": "integer"
        }
      }
    },
    "timelineEvent": {
      "type": "object",
      "required": ["observed_at", "event_type"],
      "additionalProperties": false,
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "command_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "terminal_outcome": {
          "enum": ["DELIVERED", "NO-GO", "BLOCKED"]
        },
        "terminal_reason": {
          "$ref": "#/$defs/terminalReason"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "reviewTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cycle_count": {
          "type": "integer",
          "minimum": 0
        },
        "first_review_latency_seconds": {
          "type": "number",
          "minimum": 0
        },
        "time_to_final_go_seconds": {
          "type": "number",
          "minimum": 0
        },
        "cycles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewCycleTiming"
          }
        }
      }
    },
    "reviewCycleTiming": {
      "type": "object",
      "required": ["review_cycle"],
      "additionalProperties": false,
      "properties": {
        "review_cycle": {
          "type": "integer",
          "minimum": 1
        },
        "result": {
          "enum": ["go", "no-go"]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "latency_seconds": {
          "type": "number",
          "minimum": 0
        },
        "since_previous_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "publishTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latency_seconds": {
          "type": "number",
          "minimum": 0
        },
        "pushed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "terminalReason": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_]*$"
    },
    "check": {
      "type": "object",
      "required": ["name", "status", "message"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["pass", "fail", "skip"]
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
