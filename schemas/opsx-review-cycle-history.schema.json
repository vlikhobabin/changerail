{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsx.local/schemas/opsx-review-cycle-history.schema.json",
  "title": "OPSX review cycle history",
  "type": "object",
  "required": ["schema", "updated_at", "card", "workspace", "cycles"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "opsx.review-cycle-history.v1"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "card": {
      "type": "object",
      "required": ["id", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workspace": {
      "type": "object",
      "required": ["root"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "head_commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cycles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cycle"
      }
    }
  },
  "$defs": {
    "cycle": {
      "type": "object",
      "required": [
        "review_cycle",
        "result",
        "reviewed_at",
        "verdict_path",
        "findings",
        "acceptance"
      ],
      "anyOf": [
        {
          "required": ["finding_details"]
        },
        {
          "required": ["verdict_snapshot_path"]
        }
      ],
      "additionalProperties": false,
      "properties": {
        "review_cycle": {
          "type": "integer",
          "minimum": 1
        },
        "result": {
          "enum": ["go", "no-go"]
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "verdict_path": {
          "type": "string",
          "minLength": 1
        },
        "verdict_snapshot_path": {
          "type": "string",
          "minLength": 1
        },
        "findings": {
          "type": "object",
          "required": ["blocker", "major", "minor"],
          "additionalProperties": false,
          "properties": {
            "blocker": {
              "type": "integer",
              "minimum": 0
            },
            "major": {
              "type": "integer",
              "minimum": 0
            },
            "minor": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "finding_details": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "acceptance": {
          "type": "object",
          "required": ["pass", "fail", "unverifiable", "not_applicable"],
          "additionalProperties": false,
          "properties": {
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "unverifiable": {
              "type": "integer",
              "minimum": 0
            },
            "not_applicable": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "severity", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["blocker", "major", "minor"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
