{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsx.local/schemas/opsx-review-verdict.schema.json",
  "title": "OPSX review verdict",
  "type": "object",
  "required": [
    "schema",
    "reviewed_at",
    "card",
    "workspace",
    "reviewer",
    "result",
    "acceptance",
    "findings",
    "review_cycle"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "opsx.review-verdict.v1"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "card": {
      "type": "object",
      "required": ["id", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        }
      }
    },
    "workspace": {
      "type": "object",
      "required": ["root", "head_commit", "diff_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "head_commit": {
          "type": "string",
          "minLength": 1
        },
        "diff_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "reviewer": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "codex-exec",
            "claude-subagent",
            "external-session",
            "operator"
          ]
        },
        "session": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "result": {
      "enum": ["go", "no-go"]
    },
    "review_cycle": {
      "type": "integer",
      "minimum": 1
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptanceVerdict"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "evidence_audit": {
      "type": "object",
      "required": ["claims_checked", "claims_unbacked"],
      "additionalProperties": false,
      "properties": {
        "claims_checked": {
          "type": "integer",
          "minimum": 0
        },
        "claims_unbacked": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "acceptanceVerdict": {
      "type": "object",
      "required": ["criterion", "verdict", "evidence"],
      "additionalProperties": false,
      "properties": {
        "criterion": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "enum": ["pass", "fail", "unverifiable", "not-applicable"]
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "description": "Concrete backing for the verdict: a retained evidence path, an executed command plus observed output summary, or an explicit reason why the criterion cannot be verified. Generic assurance text is not acceptable."
        }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "severity", "area", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^R[0-9]+$"
        },
        "severity": {
          "enum": ["blocker", "major", "minor"]
        },
        "area": {
          "enum": ["evidence", "code", "tests", "scope", "docs", "process"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommendation": {
          "type": "string"
        }
      }
    }
  }
}
